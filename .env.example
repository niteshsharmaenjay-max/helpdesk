# Copy to .env at the repo root to customize the docker-compose deployment.
# Every value has a default in docker-compose.yml, so this file is optional.

# Postgres credentials used by both the postgres and server containers.
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_DB=helpdesk

# Host port the client (nginx) is published on.
CLIENT_PORT=80

# Externally-visible URL of the client — used for Better Auth's cookie/CORS
# config (BETTER_AUTH_URL/TRUSTED_ORIGINS). Update this to your real domain
# in production (e.g. https://helpdesk.example.com).
PUBLIC_URL=http://localhost
