# Copy this to server/.env and fill in real values. For docker-compose,
# DATABASE_URL/SHADOW_DATABASE_URL/BETTER_AUTH_URL/TRUSTED_ORIGINS are
# overridden at the container level (see docker-compose.yml) — everything
# else here is read as-is from this file.

DATABASE_URL="postgresql://helpdesk:helpdesk@localhost:5432/helpdesk"
SHADOW_DATABASE_URL="postgresql://helpdesk:helpdesk@localhost:5432/helpdesk_shadow"
PORT=3000
BETTER_AUTH_SECRET="generate-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
TRUSTED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="Admin"
SEED_AGENT_EMAIL="agent@example.com"
SEED_AGENT_PASSWORD="change-me"
SEED_AGENT_NAME="Agent"

# Inbound email (Postmark) — the address support mail is forwarded to, and
# the Basic Auth credentials configured on the Postmark inbound webhook URL.
SUPPORT_EMAIL_ADDRESS="support@example.com"
INBOUND_EMAIL_WEBHOOK_USER="postmark"
INBOUND_EMAIL_WEBHOOK_PASSWORD="change-me"

# Gemini (used by the AI SDK for reply polishing, ticket summarization, etc.)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Outbound email (Postmark Send API) — sends agent replies to customers.
POSTMARK_SERVER_TOKEN=""
POSTMARK_FROM_ADDRESS=""
